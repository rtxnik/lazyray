.nh
.TH "LZR" "1" "Jan 2026" "lazyray" "lazyray Manual"

.SH NAME
lzr-export - Export profile as proxy URL


.SH SYNOPSIS
\fBlzr export [name] [flags]\fP


.SH DESCRIPTION
Export a proxy profile as its protocol URL (VLESS, VMess, or Trojan). Without arguments, exports the default profile.


.SH OPTIONS
\fB--all\fP[=false]
	Export all profiles

.PP
\fB--encrypt\fP[=false]
	Export all profiles encrypted (passphrase from --passphrase-file, LAZYRAY_PASSPHRASE, or prompt)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for export

.PP
\fB--passphrase-file\fP=""
	Read the encryption passphrase from the first line of this file

.PP
\fB--qr\fP[=false]
	Display proxy URL as QR code in terminal


.SH EXAMPLE
.EX
  lzr export
  lzr export home
  lzr export --all
  lzr export --qr
  lzr export --encrypt
.EE


.SH SEE ALSO
\fBlzr(1)\fP
